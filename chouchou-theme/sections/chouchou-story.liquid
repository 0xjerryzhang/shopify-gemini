<style>
  .chouchou-story-wrapper {
    display: flex;
    flex-wrap: wrap;
    background-color: var(--color-base-background-2);
    overflow: hidden;
  }
  .chouchou-story-image-col,
  .chouchou-story-text-col {
    flex: 1;
    min-width: 300px;
  }
  .chouchou-story-image-col {
    position: relative;
    min-height: 500px;
  }
  .chouchou-story-image-col img {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover;
  }
  .chouchou-story-text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8% 10%;
  }
  .chouchou-story-title {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    margin-bottom: 20px;
    line-height: 1.2;
    color: var(--color-base-text);
  }
  .chouchou-story-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-base-text-opacity-85);
    margin-bottom: 40px;
  }
  @media screen and (max-width: 768px) {
    .chouchou-story-image-col { min-height: 400px; }
    .chouchou-story-text-col { padding: 15% 8%; text-align: center; }
  }
</style>

<div class="chouchou-story-wrapper">
  {%- if section.settings.image_position == 'left' -%}
    <div class="chouchou-story-image-col">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy' }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="chouchou-story-text-col">
    <h2 class="chouchou-story-title">{{ section.settings.heading }}</h2>
    <div class="chouchou-story-content">
      {{ section.settings.text }}
    </div>
    {%- if section.settings.button_label != blank -%}
      <div>
        <a href="{{ section.settings.button_link }}" class="button">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>

  {%- if section.settings.image_position == 'right' -%}
    <div class="chouchou-story-image-col">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy' }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "ChouChou Brand Story",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        { "value": "left", "label": "Image on Left" },
        { "value": "right", "label": "Image on Right" }
      ],
      "default": "left",
      "label": "Desktop Image Position"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Maison Museau",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>Born from a love for both minimalist design and our four-legged friends, ChouChou bridges the gap between pet essentials and home aesthetics.</p>",
      "label": "Text content"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Read Our Story",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "ChouChou Brand Story"
    }
  ]
}
{% endschema %}